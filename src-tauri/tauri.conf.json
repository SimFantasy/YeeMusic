{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yee Music",
  "version": "0.3.2",
  "identifier": "com.isen.yee-music",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yee Music",
        "width": 1440,
        "height": 900,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic", "mica"]
        }
      },
      {
        "title": "TrayMenu",
        "url": "/tray-menu",
        "width": 200,
        "height": 240,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic"]
        },
        "label": "tray-menu"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/prev.png": "icons/prev.png",
      "icons/play.png": "icons/play.png",
      "icons/pause.png": "icons/pause.png",
      "icons/next.png": "icons/next.png"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5MTJFQjhERTYwNkZENDEKUldSQi9RYm1qZXNTNlVzUHBidEhhcDhuS2xFNExocTk0Y0Fldk1lb1RlaGlQNHB0S2VxVnVsaUcK",
      "active": true,
      "endpoints": [
        "https://github.com/1sen3/YeeMusicTauri/releases/download/updater/update.json"
      ]
    }
  }
}
